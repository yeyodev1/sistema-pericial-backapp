DB_URI=mongodb://localhost:27017/your-database
PORT=8100
JWT_SECRET=your_secret_key
SLACK_ERROR_WEBHOOK=

# Seed admin user
ADMIN_SEED_EMAIL=admin@sistemapericial.com
ADMIN_SEED_PASSWORD=Admin123!

# Encryption key for .p12/.pfx files stored in database
P12_MASTER_KEY=your_32_character_master_key

# Resend (email notifications)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=notificaciones@tudominio.com

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
